SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_AUTH_REDIRECT_URL=climbon://login-callback

# Optional: route photos, profile avatars, submission photos, and app visuals
# can be uploaded through your own object-storage gateway instead of Supabase
# Storage. The app sends multipart POSTs with fields: area, path, upsert, file.
OBJECT_STORAGE_UPLOAD_ENDPOINT=https://api.your-domain.ca/storage/upload
OBJECT_STORAGE_DELETE_ENDPOINT=https://api.your-domain.ca/storage/delete
OBJECT_STORAGE_PUBLIC_BASE_URL=https://media.your-domain.ca
